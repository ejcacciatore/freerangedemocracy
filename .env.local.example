# ─────────────────────────────────────────────────────────────────────────────
# FreeRangeDemocracy — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────────────────────────────────────
# Public URL of the deployed site (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://freerangedemocracy.com

# ── Admin ─────────────────────────────────────────────────────────────────────
# Password to protect admin routes (/admin/*)
# Set to any strong secret string. Leave blank to disable auth (dev only).
ADMIN_SECRET=your_admin_password_here

# ── Instagram / Meta Graph API ────────────────────────────────────────────────
# How to get these:
#   1. Go to https://developers.facebook.com and create a Meta App
#   2. Add "Instagram Graph API" product
#   3. Connect your Instagram Business or Creator account
#   4. Generate a Long-Lived User Access Token (valid 60 days)
#   5. Find your Instagram User ID via:
#      GET https://graph.facebook.com/v21.0/me?fields=id&access_token=YOUR_TOKEN

# Long-lived Instagram user access token (refresh before it expires!)
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token_here

# Your Instagram Business/Creator account user ID (a numeric string)
INSTAGRAM_USER_ID=your_instagram_user_id_here

# Meta App credentials (needed for token debug + refresh)
INSTAGRAM_APP_ID=your_meta_app_id_here
INSTAGRAM_APP_SECRET=your_meta_app_secret_here

# ─────────────────────────────────────────────────────────────────────────────
# After filling in values, restart the dev server:
#   npm run dev
#
# Admin panel URL: http://localhost:3000/admin/instagram
# ─────────────────────────────────────────────────────────────────────────────
